{
  "manifest_version": 3,
  "name": "PDF 转网页 (翻译助手)",
  "version": "1.0",
  "description": "将当前页面的 PDF 文件转换为普通网页(HTML)，以便使用谷歌浏览器自带的网页翻译功能。",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "转换为网页以供翻译",
    "default_popup": ""
  },
  "background": {
    "service_worker": "background.js"
  }
}
